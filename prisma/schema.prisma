generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organisation {
  id           String             @id @default(cuid())
  name         String
  type         String
  abn          String?
  contactEmail String?
  contactPhone String?
  address      String?
  logoUrl      String?
  isDeleted    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  invitations   Invitation[]
  users         OrganisationUser[]
  vesselGroups  VesselGroup[]
  vessels       Vessel[]
  workOrders    WorkOrder[]

  @@map("organisations")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  passwordHash         String
  firstName            String
  lastName             String
  phone                String?
  avatarUrl            String?
  isActive             Boolean               @default(true)
  lastLoginAt          DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  auditEntries         AuditEntry[]          @relation("AuditActor")
  comments             Comment[]
  mediaUploads         Media[]
  notifications        Notification[]
  organisations        OrganisationUser[]
  passwordResets       PasswordReset[]
  taskSubmissions      TaskSubmission[]
  vesselShares         VesselShare[]         @relation("VesselShareUser")
  vesselSharesGiven    VesselShare[]         @relation("VesselShareSharer")
  workOrderAssignments WorkOrderAssignment[]

  @@map("users")
}

model OrganisationUser {
  id             String       @id @default(cuid())
  userId         String
  organisationId String
  role           String
  permissions    String       @default("[]")
  isDefault      Boolean      @default(false)
  joinedAt       DateTime     @default(now())
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
  @@map("organisation_users")
}

model Invitation {
  id             String       @id @default(cuid())
  email          String
  organisationId String
  role           String
  workOrderId    String?
  assignmentRole String?
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

model VesselGroup {
  id             String                 @id @default(cuid())
  organisationId String
  name           String
  description    String?
  color          String?
  sortOrder      Int                    @default(0)
  isDeleted      Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organisation   Organisation           @relation(fields: [organisationId], references: [id])
  memberships    VesselGroupMembership[]

  @@unique([organisationId, name])
  @@map("vessel_groups")
}

model VesselGroupMembership {
  id            String      @id @default(cuid())
  vesselGroupId String
  vesselId      String
  sortOrder     Int         @default(0)
  addedAt       DateTime    @default(now())
  vesselGroup   VesselGroup @relation(fields: [vesselGroupId], references: [id], onDelete: Cascade)
  vessel        Vessel      @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@unique([vesselGroupId, vesselId])
  @@index([vesselId])
  @@map("vessel_group_memberships")
}

model Vessel {
  id                    String                  @id @default(cuid())
  organisationId        String
  externalId            String?                 @unique
  source                String?
  name                  String
  imoNumber             String?
  mmsi                  String?
  callSign              String?
  flagState             String?
  vesselType            String
  grossTonnage          Float?
  lengthOverall         Float?
  beam                  Float?
  maxDraft              Float?
  minDraft              Float?
  yearBuilt             Int?
  homePort              String?
  classificationSociety String?
  afsCoatingType        String?
  afsManufacturer       String?
  afsProductName        String?
  afsApplicationDate    DateTime?
  afsServiceLife        Int?
  lastDrydockDate       DateTime?
  nextDrydockDate       DateTime?
  typicalSpeed          Float?
  tradingRoutes         String?
  operatingArea         String?
  climateZones          String                  @default("[]")
  status                String                  @default("ACTIVE")
  complianceStatus      String                  @default("COMPLIANT")
  bfmpDocumentUrl       String?
  bfmpRevision          String?
  bfmpRevisionDate      DateTime?
  // Small base64-encoded icon image (data URL) representing the vessel.
  // Stored inline rather than in S3/CDN so a card/list view can render it
  // without extra round-trips.  Uploads are resized client-side before
  // being persisted — see `resizeImageToDataUrl` on the web client.
  iconImage             String?
  metadata              String?
  isDeleted             Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  documents             Document[]
  groupMemberships      VesselGroupMembership[]
  inspections           Inspection[]
  media                 Media[]
  nicheAreas            NicheArea[]
  components            VesselComponent[]
  organisation          Organisation            @relation(fields: [organisationId], references: [id])
  shares                VesselShare[]
  workOrders            WorkOrder[]

  @@map("vessels")
}

model VesselShare {
  id         String    @id @default(cuid())
  vesselId   String
  userId     String
  permission String    // READ or WRITE
  sharedBy   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  vessel     Vessel    @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  user       User      @relation("VesselShareUser", fields: [userId], references: [id], onDelete: Cascade)
  sharer     User      @relation("VesselShareSharer", fields: [sharedBy], references: [id])

  @@unique([vesselId, userId])
  @@index([userId])
  @@map("vessel_shares")
}

model NicheArea {
  id                 String              @id @default(cuid())
  vesselId           String
  name               String
  location           String?
  afsType            String?
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inspectionFindings InspectionFinding[]
  vessel             Vessel              @relation(fields: [vesselId], references: [id], onDelete: Cascade)

  @@map("niche_areas")
}

// General Arrangement - underwater components making up the digital twin
model VesselComponent {
  id            String            @id @default(cuid())
  vesselId      String
  parentId      String?
  name          String
  category      String
  location      String?
  description   String?
  sortOrder     Int               @default(0)
  coatingType   String?
  material      String?
  lastInspected DateTime?
  condition     String?
  gaZoneId      String?
  isoZone       String?           // ISO 6319:2026 Annex D zone mapping
  metadata      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  parent        VesselComponent?  @relation("SubComponents", fields: [parentId], references: [id], onDelete: Cascade)
  children      VesselComponent[] @relation("SubComponents")
  vessel        Vessel            @relation(fields: [vesselId], references: [id], onDelete: Cascade)
  workFormEntries WorkFormEntry[]

  @@map("vessel_components")
}

model WorkFormEntry {
  id                String          @id @default(cuid())
  workOrderId       String
  vesselComponentId String
  isoZone           String?         // ISO 6319:2026 Annex D zone (inherited from component or overridden)
  condition         String?
  foulingRating     Int?
  foulingType       String?
  coverage          Float?
  measurementType   String?
  measurementValue  Float?
  measurementUnit   String?
  coatingCondition  String?
  corrosionType     String?
  corrosionSeverity String?
  notes             String?
  recommendation    String?
  actionRequired    Boolean         @default(false)
  attachments       String          @default("[]")
  status            String          @default("PENDING")
  completedAt       DateTime?
  completedBy       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  vesselComponent   VesselComponent @relation(fields: [vesselComponentId], references: [id])
  workOrder         WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, vesselComponentId])
  @@map("work_form_entries")
}

model VideoRoom {
  id          String    @id @default(cuid())
  workOrderId String    @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("video_rooms")
}

model WorkOrder {
  id                  String                @id @default(cuid())
  referenceNumber     String                @unique
  vesselId            String
  organisationId      String
  workflowId          String?
  title               String
  description         String?
  type                String
  foulingScale        String?
  priority            String                @default("NORMAL")
  status              String                @default("DRAFT")
  location            String?
  latitude            Float?
  longitude           Float?
  scheduledStart      DateTime?
  scheduledEnd        DateTime?
  actualStart         DateTime?
  actualEnd           DateTime?
  currentStepId       String?
  currentTaskId       String?
  regulatoryRef       String?
  complianceFramework String                @default("[]")
  metadata            String?
  isDeleted           Boolean               @default(false)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  completedAt         DateTime?
  comments            Comment[]
  documents           Document[]
  inspections         Inspection[]
  media               Media[]
  taskSubmissions     TaskSubmission[]
  videoRoom           VideoRoom?
  formEntries         WorkFormEntry[]
  assignments         WorkOrderAssignment[]
  organisation        Organisation          @relation(fields: [organisationId], references: [id])
  vessel              Vessel                @relation(fields: [vesselId], references: [id])
  workflow            Workflow?             @relation(fields: [workflowId], references: [id])

  @@index([organisationId, status, isDeleted])
  @@index([vesselId])
  @@map("work_orders")
}

model WorkOrderAssignment {
  id          String    @id @default(cuid())
  workOrderId String
  userId      String
  role        String
  assignedAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, userId])
  @@map("work_order_assignments")
}

model Inspection {
  id                String              @id @default(cuid())
  workOrderId       String
  vesselId          String
  type              String
  status            String              @default("IN_PROGRESS")
  inspectorName     String
  inspectorOrg      String?
  inspectorCert     String?
  waterTemp         Float?
  waterVisibility   Float?
  isoVisibility     String?           // ISO 6319:2026 Table B.1 visibility condition
  waterSalinity     Float?
  weatherConditions String?
  seaState          String?
  tideState         String?
  location          String?
  latitude          Float?
  longitude         Float?
  overallRating     Int?
  summary           String?
  recommendations   String?
  startedAt         DateTime            @default(now())
  completedAt       DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  findings          InspectionFinding[]
  vessel            Vessel              @relation(fields: [vesselId], references: [id])
  workOrder         WorkOrder           @relation(fields: [workOrderId], references: [id])
  media             Media[]

  @@index([workOrderId])
  @@index([vesselId])
  @@map("inspections")
}

model InspectionFinding {
  id                String     @id @default(cuid())
  inspectionId      String
  nicheAreaId       String?
  area              String
  foulingRating     Int?
  foulingType       String?
  coverage          Float?
  condition         String?
  measurementType   String?
  measurementValue  Float?
  measurementUnit   String?
  isoZone           String?    // ISO 6319:2026 Annex D zone (denormalised from component)
  referenceStandard String?
  coatingCondition  String?
  corrosionType     String?
  corrosionSeverity String?
  description       String?
  recommendation    String?
  actionRequired    Boolean    @default(false)
  priority          String     @default("NORMAL")
  metadata          String?
  createdAt         DateTime   @default(now())
  inspection        Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  nicheArea         NicheArea? @relation(fields: [nicheAreaId], references: [id])
  media             Media[]

  @@map("inspection_findings")
}

model Workflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  version     Int            @default(1)
  isActive    Boolean        @default(true)
  isTemplate  Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workOrders  WorkOrder[]
  steps       WorkflowStep[]

  @@map("workflows")
}

model WorkflowStep {
  id                 String         @id @default(cuid())
  workflowId         String
  name               String
  description        String?
  order              Int
  type               String
  requiredRole       String?
  requiredPermission String?
  autoAdvance        Boolean        @default(false)
  createdAt          DateTime       @default(now())
  workflow           Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tasks              WorkflowTask[]

  @@unique([workflowId, order])
  @@map("workflow_steps")
}

model WorkflowTask {
  id          String           @id @default(cuid())
  stepId      String
  name        String
  description String?
  order       Int
  isRequired  Boolean          @default(true)
  taskType    String
  config      String?
  createdAt   DateTime         @default(now())
  submissions TaskSubmission[]
  step        WorkflowStep     @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([stepId, order])
  @@map("workflow_tasks")
}

model TaskSubmission {
  id          String       @id @default(cuid())
  taskId      String
  workOrderId String
  userId      String
  status      String       @default("PENDING")
  data        String       @default("{}")
  notes       String?
  signature   String?
  submittedAt DateTime?
  reviewedAt  DateTime?
  reviewedBy  String?
  reviewNotes String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  media       Media[]
  task        WorkflowTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  workOrder   WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([taskId])
  @@map("task_submissions")
}

model Media {
  id           String             @id @default(cuid())
  uploaderId   String
  vesselId     String?
  workOrderId  String?
  inspectionId String?
  findingId    String?
  submissionId String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  storageKey   String
  url          String
  thumbnailUrl String?
  capturedAt   DateTime?
  latitude     Float?
  longitude    Float?
  deviceInfo   String?
  tags         String             @default("[]")
  createdAt    DateTime           @default(now())
  finding      InspectionFinding? @relation(fields: [findingId], references: [id], onDelete: SetNull)
  inspection   Inspection?        @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  submission   TaskSubmission?    @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  uploader     User               @relation(fields: [uploaderId], references: [id])
  vessel       Vessel?            @relation(fields: [vesselId], references: [id])
  workOrder    WorkOrder?         @relation(fields: [workOrderId], references: [id])

  @@index([workOrderId])
  @@index([uploaderId])
  @@map("media")
}

model Document {
  id            String     @id @default(cuid())
  vesselId      String?
  workOrderId   String?
  name          String
  type          String
  version       Int        @default(1)
  storageKey    String
  url           String
  size          Int
  mimeType      String
  generatedFrom String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  vessel        Vessel?    @relation(fields: [vesselId], references: [id])
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id])

  @@map("documents")
}

model Comment {
  id          String    @id @default(cuid())
  workOrderId String
  authorId    String
  parentId    String?
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id])
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[] @relation("CommentReplies")
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model AuditEntry {
  id            String   @id @default(cuid())
  sequence      Int      @unique
  actorId       String?
  actorEmail    String?
  actorOrg      String?
  entityType    String
  entityId      String
  action        String
  description   String
  previousData  String?
  newData       String?
  changedFields String   @default("[]")
  hash          String
  previousHash  String?
  ipAddress     String?
  userAgent     String?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  actor         User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
  @@map("audit_entries")
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}
